# Database - Use standard PostgreSQL connection string
# For local dev: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/platform?schema=public"

# NextAuth (Auth.js v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Public app URL (used for referral links, webhooks, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Encryption key for storing Lipana credentials (must be exactly 32 bytes/characters)
ENCRYPTION_KEY="32-character-key-for-aes-256-gcm"

# Supabase – required for transcription submissions & media tasks
# Find these in your Supabase project Settings > API
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-secret>"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-public-key>"

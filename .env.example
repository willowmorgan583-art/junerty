# Database - Use standard PostgreSQL connection string
# For local dev: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/platform?schema=public"

# NextAuth (Auth.js v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
